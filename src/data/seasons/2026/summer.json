  "rules": {
    "summary": "2026 KPL夏季赛沿用 SAB 三轮循环 + 卡位赛赛制。18支战队经抽签进入三组进行第一轮；按积分进入第二轮 S/A/B 组；卡位赛后 B 组出局；第三轮决定季后赛席位。",
    "stages": [
      {
        "id": "stage1",
        "name": "第一轮循环赛",
        "format": "三组（每组6队）BO5 组内单循环；胜积1分。各组1-2名进S组，3-4名进A组，5-6名进B组。积分成绩清零进入下一轮。",
        "period": "2026-06-17 ~ 2026-07-05"
      },
      {
        "id": "stage2",
        "name": "第二轮循环赛",
        "format": "S/A/B 组各自 BO5 组内单循环。结束后：S5-S6 与 A1-A2 打卡位赛；A5-A6 与 B1-B2 打卡位赛；B3-B6 淘汰。",
        "period": "2026-07-09 ~ 2026-07-26"
      },
      {
        "id": "seat",
        "name": "卡位赛",
        "format": "BO7。胜者升组/保组，负者降组/淘汰。卡位赛后 B 组全部出局。",
        "period": "2026-07-27 ~ 2026-07-28"
      },
      {
        "id": "stage3",
        "name": "第三轮循环赛",
        "format": "S/A 两组 BO5 组内单循环（积分清零）。S组全部 + A组前4 晋级季后赛；A5-A6 淘汰。",
        "period": "2026-07-30 ~ 2026-08-23"
      },
      {
        "id": "playoffs",
        "name": "季后赛",
        "format": "BO7 双败淘汰；全局BP + 第7局巅峰对决。S1-S4 进胜者组，S5-S6 进败者组R2，A1-A4 进败者组R1。",
        "period": "2026-08-27 ~ 2026-09-06"
      },
      {
        "id": "finals",
        "name": "总决赛",
        "format": "BO7，厦门凤凰体育馆。",
        "period": "2026-09-12"
